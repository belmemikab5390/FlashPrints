# ── Booth Identity ──
BOOTH_ID=001
BOOTH_LOCATION=SM City North EDSA
BOOTH_FLOOR=Level 2

# ── GCash Merchant API ──
GCASH_MERCHANT_ID=your_merchant_id_here
GCASH_CLIENT_ID=your_client_id_here
GCASH_CLIENT_SECRET=your_client_secret_here
GCASH_ENV=sandbox
# Change to: https://api.globelabs.com.ph for production
GCASH_API_URL=https://devapi.globelabs.com.ph

# ── Server ──
SERVER_PORT=3000
WEBHOOK_SECRET=your_webhook_secret_here
# Public base URL used for QR code links (set to your LAN IP so phones can scan)
PUBLIC_URL=http://localhost:3000

# ── Printer ──
PRINTER_NAME=DNP DS620A
PRINTER_WIDTH=2
PRINTER_HEIGHT=6

# ── Owner Dashboard ──
DASHBOARD_PORT=4000
DASHBOARD_PASSWORD=your_dashboard_password_here

# ── App ──
NODE_ENV=production
IDLE_TIMEOUT_MS=180000
QR_EXPIRY_MS=600000

# ── Supply Thresholds ──
PAPER_START=200
SUPPLY_WARN_PAPER=30
SUPPLY_CRIT_PAPER=10
SUPPLY_WARN_INK=25
SUPPLY_CRIT_INK=10
PRINTER_SIMULATE=true

# ── Camera / DSLR ──
CAMERA_SIMULATE=true
DSLR_CLI_PATH=C:\Program Files\Breeze Systems\DSLR Remote Pro\DSLRRemotePro.exe
CAPTURE_DIR=./captures
PREVIEW_DIR=./captures/preview
PREVIEW_FPS=15

# ── Watchdog ──
WATCHDOG_MAX_CRASHES=10
WATCHDOG_RESTART_DELAY=8000
WATCHDOG_DAILY_RESTART_HOUR=4
