{
  "name": "flash-and-prints",
  "version": "1.0.0",
  "description": "Flash & Prints — Unattended GCash Photobooth Kiosk",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build-win": "electron-builder --win --x64",
    "server": "node server/index.js",
    "watchdog": "node watchdog.js",
    "watchdog:dev": "node watchdog.js --dev",
    "service:install": "node watchdog-service.js install",
    "service:remove": "node watchdog-service.js uninstall",
    "service:status": "node watchdog-service.js status",
    "pm2:start": "node watchdog-service.js pm2",
    "install:sharp": "npm install sharp canvas"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "node-thermal-printer": "^4.3.2",
    "qrcode": "^1.5.3",
    "sharp": "^0.33.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "ph.flashandprints.kiosk",
    "productName": "Flash & Prints Photobooth",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "createDesktopShortcut": true
    }
  }
}
